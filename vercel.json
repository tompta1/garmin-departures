{
  "regions": ["fra1"],
  "functions": {
    "api/nearby-departures.ts": {
      "includeFiles": "data/stops-index.json|data/stops-index-jmk.json",
      "maxDuration": 30
    },
    "api/cron-refresh-jmk.ts": {
      "maxDuration": 300
    },
    "api/cron-refresh-iredo.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron-refresh-jmk",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron-refresh-iredo",
      "schedule": "30 3 * * *"
    }
  ]
}
